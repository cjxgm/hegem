name "Glasses"

views {
    view {
        name "Main"
        dimension 800 600
        bounces 6
        samples 32
        perspective-camera {
            center 0 0 5
            direction 0 0 -1
            up 0 1 0
            angle 60
        }
    }
}

lights {
    directional-light {
        direction 2 -2 -1
        color 1 1 1
        strength 20
    }
    directional-light {
        direction -1 1 -1
        color 1 1 1
        strength 16
    }
}

background {
    color 0.9 0.9 1
    strength 10
}

