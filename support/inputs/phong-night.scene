name "Phong Night"

views {
    view {
        name "Main View"
        dimension 800 480
        bounces 3
        samples 4
        perspective-camera {
            center -0.2 -0.5 5
            direction 0.2 0 -1
            up 0.1 1 0
            angle 60
        }
    }
}

lights {
    directional-light {
        direction 2 -2 -1
        color 1 0.9 0.8
        strength 1
    }
    point-light {
        center 2 -1.5 1
        color 1 0.5 0.1
        strength 50
    }
}

background {
    color 0.3 0.3 1
    strength 1
}

materials {
    phong-material {
        diffuse-color 0.1 0.1 0.1
        reflection-color 0.2 0.2 0.2
        refraction-color 0.7 0.7 0.7
        specular-color 1 1 1
        exponent 32
        index-of-refraction 1.45
    }
    phong-material {
        diffuse-color 0.05 1 0.05
        reflection-color 0 0 0
        refraction-color 0 0 0
        specular-color 1 1 1
        exponent 32
        index-of-refraction 0
    }
    phong-material {
        diffuse-color 0.2 0.2 0.2
        reflection-color 0.7 0.6 0.5
        refraction-color 0 0 0
        specular-color 0 0 0
        exponent 0
        index-of-refraction 0
    }
    phong-material {
        diffuse-color 0.1 0.3 0.05
        reflection-color 0.1 0.1 0.1
        refraction-color 0 0 0
        specular-color 1 1 1
        exponent 2
        index-of-refraction 0
    }
}

group {
    object {
        material-id 0
        sphere {
            center 0 0 0
            radius 1
        }
    }

    object {
        material-id 1
        sphere {
            center 1 1 1
            radius 0.75
        }
    }
    object {
        material-id 1
        sphere {
            center -1 -1.8 1
            radius 0.75
        }
    }

    object {
        material-id 2
        sphere {
            center -1 1 -1
            radius 0.75
        }
    }
    object {
        material-id 2
        sphere {
            center 1 -1 -1
            radius 0.75
        }
    }

    object {
        material-id 3
        plane {
            normal 0 1 0
            offset -2
        }
    }
}

