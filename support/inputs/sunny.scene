name "Sunny"

views {
    view {
        name "Main Pos"
        dimension 800 480
        bounces 3
        perspective-camera {
            center -0.2 -0.5 5
            direction 0.2 0 -1
            up 0.1 1 0
            angle 60
        }
    }

    view {
        name "High Pos"
        dimension 800 480
        bounces 3
        perspective-camera {
            center 1 2 5
            direction -0.2 -0.5 -1
            up 0.1 1 0
            angle 60
        }
    }

    view {
        name "Low Pos"
        dimension 800 480
        bounces 6
        perspective-camera {
            center 2 -0.9 4
            direction -0.2 0.3 -0.9
            up 0.1 1 0
            angle 60
        }
    }

    view {
        name "Opposite Pos"
        dimension 800 480
        bounces 4
        perspective-camera {
            center -1 0.5 -5
            direction 0.2 -0.2 1
            up 0.1 1 0
            angle 45
        }
    }

    view {
        name "Oppo Zoom In"
        dimension 800 480
        bounces 4
        perspective-camera {
            center -1 0.5 -5
            direction 0.2 -0.2 1
            up 0.1 1 0
            angle 10
        }
    }

    view {
        name "Oppo Zoom Out"
        dimension 800 480
        bounces 4
        perspective-camera {
            center -1 0.5 -5
            direction 0.2 -0.2 1
            up 0.1 1 0
            angle 90
        }
    }
}

lights {
    directional-light {
        direction 1 -1 2
        color 1 0.9 0.8
        strength 10
    }
}

background {
    color 0.3 0.3 1
    strength 10
}

materials {
    pbr-material {
        color 0.4 0.25 0.05
        roughness 0.002
        metalness 1
        index-of-refraction 50
    }
    pbr-material {
        color 0.05 1 0.05
        roughness 0.3
        metalness 0
        index-of-refraction 1.5
    }
    pbr-material {
        color 1 0.5 0.01
        roughness 0.2
        metalness 0.4
        index-of-refraction 10
    }
    pbr-material {
        color 0.1 0.3 0.05
        roughness 0.95
        metalness 0
        index-of-refraction 1.5
    }
}

group {
    object {
        material-id 0
        sphere {
            center 0 0 0
            radius 1
        }
    }

    object {
        material-id 1
        sphere {
            center 1 1 1
            radius 0.75
        }
    }
    object {
        material-id 1
        sphere {
            center -1 -1.8 1
            radius 0.75
        }
    }

    object {
        material-id 2
        sphere {
            center -1 1 -1
            radius 0.75
        }
    }
    object {
        material-id 2
        sphere {
            center 1 -1 -1
            radius 0.75
        }
    }

    object {
        material-id 3
        plane {
            normal 0 1 0
            offset -2
        }
    }
}

