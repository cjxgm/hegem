name "PBR Balls"

views {
    view {
        name "Preview"
        dimension 800 450
        bounces 8
        perspective-camera {
            center 0 0 5
            direction 0 0 -1
            up 0 1 0
            angle 30
        }
    }

    view {
        name "HD"
        dimension 1920 1080
        bounces 16
        perspective-camera {
            center 0 0 5
            direction 0 0 -1
            up 0 1 0
            angle 60
        }
    }
}

